---
kind: "StorageVersionMigration"
api_family: "migration.k8s.io"
default_command: "storageversionmigrations"
listview:
  name: "Storage Version Migrations"
  group: "Storage & Backups"
  field_indexes:
    Normal:
      fields: ["name", "controller", "age"]
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
infoview:
  name: "Storage Version Migration Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "resource", "api_group", "version"]
    rows:
      api_group:
        header: [["API-Group:", ["main", "infoheader"]]]
        path: "spec#resource#group"
        type: "str"
        formatting:
          field_colors:
            - type: "api_group"
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      resource:
        header: [["Resource:", ["main", "infoheader"]]]
        path: "spec#resource#resource"
        type: "str"
      version:
        header: [["Version:", ["main", "infoheader"]]]
        path: "spec#resource#version"
        type: "str"
        formatting:
          field_colors:
            - type: "version"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
