---
kind: "KubevirtMachine"
api_family: "infrastructure.cluster.x-k8s.io"
default_command: "kubevirtmachines"
command:
  - "kvmachs"
  - "kvmach"
listview:
  name: "Kubevirt Machines"
  group: "Cluster Configuration"
  field_indexes:
    Wide:
      fields: ["namespace", "name", "controller", "provider_id", "age"]
      sortcolumn: "namespace"
    Normal:
      fields: ["namespace", "name", "provider_id", "age"]
      sortcolumn: "namespace"
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    provider_id:
      header: "Provider ID:"
      path: "spec#providerID"
      type: "str"
infoview:
  name: "Kubevirt Machine Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "provider_id",
                 "vm_bootstrap_check_strategy",
                 "node_updated", "ready"]
    rows:
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      node_updated:
        header: [["Node Updated:", ["main", "infoheader"]]]
        path: "status#nodeupdated"
        default: "<unset>"
        type: "bool"
        formatter: "value_mapper"
        formatting:
          mapping:
            mappings:
              "True":
                field_colors:
                  - context: "main"
                    type: "status_ok"
              "False":
                field_colors:
                  - context: "main"
                    type: "status_pending"
      provider_id:
        header: [["Provider ID:", ["main", "infoheader"]]]
        path: "spec#providerID"
        type: "str"
      ready:
        header: [["Ready:", ["main", "infoheader"]]]
        paths:
          - path: "status#conditions"
            pathtype: "items"
            subpath: "status"
            when:
              - key: "type"
                eq: "Ready"
            default: ["False"]
        type: "str"
        formatter: "value_mapper"
        formatting:
          mapping:
            mappings:
              "True":
                field_colors:
                  - context: "main"
                    type: "status_ok"
              "False":
                field_colors:
                  - context: "main"
                    type: "status_pending"
      vm_bootstrap_check_strategy:
        header: [["Virtual Machine Bootstrap Check Strategy:",
                  ["main", "infoheader"]]]
        path: "spec#virtualMachineBootstrapCheck#checkStrategy"
        default: "<unset>"
        type: "str"
  shortcuts:
    "Addresses":
      key: "a"
      modifier: "shift"
      read_only: true
      helptext: "List addresses"
      widget: "windowwidget"
      widget_args:
        title: "Addresses:"
        headers: ["Address:", "Type:"]
        itemgetter: "get_list_fields"
        itemgetter_args:
          path: "status#addresses"
          fields:
            - "address"
            - "type"
        # Not supported for now
        sortcolumn: "type"
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    "Virtual Cluster Template":
      key: "t"
      modifier: "shift"
      read_only: true
      helptext: "Show virtual cluster template"
      action: "call"
      action_call: "view_yaml"
      action_args:
        title: "Virtual Cluster Template"
        _pass_obj: true
        path: "spec#virtualMachineTemplate"
