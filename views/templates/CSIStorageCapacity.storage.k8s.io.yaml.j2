---
kind: "CSIStorageCapacity"
api_family: "storage.k8s.io"
default_command: "csistoragecapacities"
command:
  - "csistoragecaps"
  - "csistoragecap"
listview:
  name: "CSI Storage Capacities"
  group: "Storage & Backups"
  field_indexes:
    Normal:
      fields: ["namespace", "name", "controller", "storage_class_name", "age"]
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    storage_class_name:
      header: "Storage Class Name:"
      path: "storageClassName"
      type: "str"
infoview:
  name: "CSI Storage Capacity Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "storage_class", "node_topology_header",
                 "node_topology_label_selector",
                 "node_topology_set_based_selector", "capacity"]
    rows:
      capacity:
        header: [["Capacity:", ["main", "infoheader"]]]
        path: "capacity"
        type: "str"
        formatter: "numerical"
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      node_topology_header:
        header: [["Node Topology:", ["main", "infoheader"]]]
      node_topology_label_selector:
        header: [["  La", ["main", "infoheader"]],
                 ["b", ["main", "infoheader_shortcut"]],
                 ["el Selector:", ["main", "infoheader"]]]
        paths:
          - path: ["nodeTopology#matchLabels"]
            pathtype: "key_value"
            default: ["<none>"]
        formatter: "list"
        formatting:
          field_colors:
            - type: "key"
            - type: "value"
          field_separators:
            - type: "selector"
      node_topology_set_based_selector:
        header: [["  Set-based Selector:", ["main", "infoheader"]]]
        paths:
          - path: "nodeTopology#matchExpressions"
            pathtype: "match_expression"
            default: "<none>"
        formatter: "list"
        formatting:
          field_colors:
            - type: "key"
            - type: "operator"
            - type: "value"
          field_separators:
            - type: "space"
            - type: "no_pad"
      storage_class:
        header: [["S", ["main", "infoheader_shortcut"]],
                 ["torage Class:", ["main", "infoheader"]]]
        path: "storageClassName"
        default: "<none>"
        type: "str"
  shortcuts:
    "Node Topology Label Selector":
      key: "b"
      read_only: true
      helptext: "Show Node topology label selector"
      widget: "windowwidget"
      widget_args:
        title: "Node Topology Label Selector:"
        headers: ["Key:", "Value:"]
        itemgetter: "get_key_value"
        itemgetter_args:
          path: "nodeTopology#matchLabels"
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    "Open Storage Class":
      key: "s"
      modifier: "shift"
      read_only: true
      helptext: "Open info page for Storage Class"
      action: "call"
      action_call: "resourceinfodispatch_with_lookup"
      action_args:
        _pass_obj: true
        kind: "StorageClass"
        api_family: "storage.k8s.io"
        name_path: "storageClassName"
