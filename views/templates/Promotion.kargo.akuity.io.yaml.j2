---
kind: "Promotion"
api_family: "kargo.akuity.io"
default_command: "promotions"
command:
  - "kargopromotions"
  - "kargopromotion"
  - "kargoproms"
  - "kargoprom"
  - "promos"
  - "promo"
listview:
  name: "Promotions"
  group: "CI / CD"
  field_indexes:
    Wide:
      fields: ["namespace", "name", "controller", "stage", "freight", "phase",
               "age", "message"]
      sortcolumn: "namespace"
    Normal:
      fields: ["namespace", "name", "stage", "freight", "phase",
               "age", "message"]
      sortcolumn: "namespace"
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    freight:
      header: "Freight:"
      path: "spec#freight"
      type: "str"
    message:
      header: "Message:"
      path: "status#message"
      default: "<unset>"
      type: "str"
    phase:
      header: "Phase:"
      path: "status#phase"
      type: "str"
      formatter: "value_mapper"
      formatting:
        mapping:
          mappings:
            Errored:
              field_colors:
                - context: "main"
                  type: "status_not_ok"
            Failed:
              field_colors:
                - context: "main"
                  type: "status_not_ok"
            Pending:
              field_colors:
                - context: "main"
                  type: "status_pending"
            Running:
              field_colors:
                - context: "main"
                  type: "status_ok"
            Succeeded:
              field_colors:
                - context: "main"
                  type: "status_ok"
    stage:
      header: "Stage:"
      path: "spec#stage"
      type: "str"
infoview:
  name: "Promotion Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "stage", "freight", "phase",
                 "message", "finished_at"]
    rows:
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      finished_at:
        header: [["Finished At:", ["main", "infoheader"]]]
        path: "status#finishedAt"
        type: "timestamp"
        formatter: "timestamp"
        default: -1
      freight:
        header: [["Freight:", ["main", "infoheader"]]]
        path: "spec#freight"
        type: "str"
      message:
        header: [["Message:", ["main", "infoheader"]]]
        path: "status#message"
        default: "<unset>"
        type: "str"
      phase:
        header: [["Phase:", ["main", "infoheader"]]]
        path: "status#phase"
        type: "str"
        formatter: "value_mapper"
        formatting:
          mapping:
            mappings:
              Errored:
                field_colors:
                  - context: "main"
                    type: "status_not_ok"
              Failed:
                field_colors:
                  - context: "main"
                    type: "status_not_ok"
              Pending:
                field_colors:
                  - context: "main"
                    type: "status_pending"
              Running:
                field_colors:
                  - context: "main"
                    type: "status_ok"
              Succeeded:
                field_colors:
                  - context: "main"
                    type: "status_ok"
      stage:
        header: [["Stage:", ["main", "infoheader"]]]
        path: "spec#stage"
        type: "str"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
