---
kind: "Suggestion"
api_family: "kubeflow.org"
default_command: "suggestions"
listview:
  name: "Suggestions"
  group: "Kubeflow"
  field_indexes:
    Normal:
      fields: ["namespace", "name", "controller", "age"]
      sortcolumn: "namespace"
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
infoview:
  name: "Suggestion Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "algorithm", "resume_policy",
                 "requests", "suggestions"]
    rows:
      algorithm:
        header: [["Algorithm:", ["main", "infoheader"]]]
        path: "spec#algorithm#algorithmName"
        default: "<unset>"
        type: "str"
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      requests:
        header: [["Requests:", ["main", "infoheader"]]]
        path: "spec#requests"
        default: "<unset>"
        type: "int"
        formatter: "numerical"
      resume_policy:
        header: [["Resume Policy:", ["main", "infoheader"]]]
        path: "spec#resumePolicy"
        default: "<unset>"
        type: "str"
      suggestions:
        header: [["Suggestions:", ["main", "infoheader"]]]
        path: "status#suggestionCount"
        default: "<unset>"
        type: "int"
        formatter: "numerical"
  listpad:
    listgetter: "listgetter_path"
    listgetter_args:
      path: "status#suggestions"
    infogetter: "generic_infogetter"
    field_indexes:
      Normal:
        fields: ["name", "parameters"]
        sortcolumn: "priority"
    fields:
      name:
        header: "Name:"
        path: "name"
        type: "str"
      parameters:
        header: "Parameters:"
        paths:
          - path: "parameterAssignments"
            pathtype: "key_value"
            default: ["<none>"]
        formatter: "list"
        formatting:
          field_colors:
            - type: "key"
            - type: "value"
          field_separators:
            - type: "selector"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
