---
kind: "Ingress"
api_family: "networking.internal.knative.dev"
default_command: "ingresses.networking.internal.knative.dev"
command:
  - "ingresses.knative"
  - "ingress.knative"
  - "kningresses"
  - "kningress"
listview:
  name: "Ingresses"
  group: "Knative"
  field_indexes:
    Normal:
      fields: ["namespace", "name", "controller",
               "condition_ready", "age", "reason"]
      sortcolumn: "namespace"
  fields:
    {%- for line in field_condition_ready.split("\n") %}
    {{ line }}
    {%- endfor %}
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    reason:
      header: "Reason:"
      paths:
        - path: "status#conditions"
          pathtype: "items"
          subpath: "message"
          when:
            - key: "type"
              eq: "Ready"
      type: "str"
  actions:
    actionlist:
      "Delete resource":
        description: "Delete resource"
        category: "Resource Level"
        confirm: true
        actionfunc: "delete_resource"
infoview:
  name: "Ingress Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "http_option", "condition_ready", "reason"]
    rows:
      {%- for line in row_condition_ready.split("\n") %}
      {{ line }}
      {%- endfor %}
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      http_option:
        header: [["HTTP Option:", ["main", "infoheader"]]]
        path: "spec#httpOption"
        default: "<unset>"
        type: "str"
      reason:
        header: [["Reason:", ["main", "infoheader"]]]
        paths:
          - path: "status#conditions"
            pathtype: "items"
            subpath: "message"
            when:
              - key: "type"
                eq: "Ready"
        type: "list"
        formatter: "list"
  listpad:
    listgetter: "listgetter_path"
    listgetter_args:
      path: "spec#rules"
    infogetter: "generic_infogetter"
    field_indexes:
      Normal:
        fields: ["hosts", "visibility", "http"]
        sortcolumn: "hosts"
    fields:
      hosts:
        header: "Hosts:"
        path: "hosts"
        type: "raw"
        formatter: "list"
      http:
        header: "HTTP:"
        path: "http"
        type: "raw"
      visibility:
        header: "Visibility:"
        path: "visibility"
        type: "str"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
