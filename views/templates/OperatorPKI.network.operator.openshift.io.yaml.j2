---
kind: "OperatorPKI"
api_family: "network.operator.openshift.io"
default_command: "operatorpkis"
listview:
  name: "Operator PKIs"
  group: "OpenShift"
  field_indexes:
    Wide:
      fields: ["namespace", "name", "controller", "target_certificate", "age"]
      sortcolumn: "namespace"
    Normal:
      fields: ["namespace", "name", "target_certificate", "age"]
      sortcolumn: "namespace"
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    target_certificate:
      header: "Target Certificate:"
      path: "spec#targetCert#commonName"
      default: "<unset>"
      type: "str"
infoview:
  name: "Operator PKI Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "target_certificate"]
    rows:
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      target_certificate:
        header: [["Target Certificate:", ["main", "infoheader"]]]
        path: "spec#targetCert#commonName"
        default: "<unset>"
        type: "str"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
