---
kind: "ClusterRole"
api_family: "rbac.authorization.k8s.io"
default_command: "clusterroles"
command:
  - "clrroles"
  - "clrrole"
  - "clr"
listview:
  name: "Cluster Roles"
  group: "Authorization & Access Control"
  field_indexes:
    Normal:
      fields: ["name", "controller", "rules", "age"]
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    rules:
      header: "Rules:"
      path: "rules"
      type: "len"
      formatter: "numerical"
      align: "right"
  actions:
    actionlist:
      "Delete resource":
        description: "Delete resource"
        category: "Resource Level"
        confirm: true
        actionfunc: "delete_resource"
infoview:
  name: "Cluster Role Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller",
                 "aggregation_rule_header",
                 "aggregation_rule_cluster_role_selectors"]
    rows:
      aggregation_rule_header:
        header: [["Aggregation Rule:", ["main", "infoheader"]]]
      aggregation_rule_cluster_role_selectors:
        header: [["  Cluster Role ", ["main", "infoheader"]],
                 ["S", ["main", "infoheader_shortcut"]],
                 ["electors:", ["main", "infoheader"]]]
        paths:
          - path: ["aggregationRule#clusterRoleSelectors"]
            pathtype: "selectors"
            default: ["<none>"]
        formatter: "list"
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
  listpad:
    listgetter: "listgetter_policy_rules"
    infogetter: "generic_infogetter"
    field_indexes:
      Wide:
        fields: ["resource", "api_group",
                 "verbs_all", "verbs_get", "verbs_list",
                 "verbs_watch", "verbs_create", "verbs_update",
                 "verbs_patch", "verbs_delete", "verbs_misc",
                 "non_resource_urls", "resource_names"]
        sortcolumn: "api_group"
      Normal:
        fields: ["resource", "api_group", "verbs",
                 "non_resource_urls", "resource_names"]
        sortcolumn: "api_group"
    fields:
      api_group:
        header: "API-Group:"
        path: "api_group"
        type: "str"
      non_resource_urls:
        header: "Non-Resource URLs:"
        path: "non_resource_urls"
        type: "raw"
        formatter: "list"
      resource:
        header: "Resource:"
        path: "resource"
        type: "str"
      resource_names:
        header: "Resource Names:"
        path: "resource_names"
        type: "raw"
        formatter: "list"
      verbs:
        header: "Verbs:"
        path: "verbs"
        type: "raw"
        formatter: "list"
      verbs_all:
        header: "All:"
        path: "verbs_all"
        type: "bool"
        formatter: "value_mapper"
        formatting:
          mapping:
            substitutions:
              "True":
                context: "strings"
                type: "positive_check"
              "False":
                context: "strings"
                type: "negative_ballot"
      verbs_create:
        header: "Create:"
        path: "verbs_create"
        type: "bool"
        formatter: "value_mapper"
        formatting:
          mapping:
            substitutions:
              "True":
                context: "strings"
                type: "positive_check"
              "False":
                context: "strings"
                type: "negative_ballot"
      verbs_delete:
        header: "Delete:"
        path: "verbs_delete"
        type: "bool"
        formatter: "value_mapper"
        formatting:
          mapping:
            substitutions:
              "True":
                context: "strings"
                type: "positive_check"
              "False":
                context: "strings"
                type: "negative_ballot"
      verbs_get:
        header: "Get:"
        path: "verbs_get"
        type: "bool"
        formatter: "value_mapper"
        formatting:
          mapping:
            substitutions:
              "True":
                context: "strings"
                type: "positive_check"
              "False":
                context: "strings"
                type: "negative_ballot"
      verbs_list:
        header: "List:"
        path: "verbs_list"
        type: "bool"
        formatter: "value_mapper"
        formatting:
          mapping:
            substitutions:
              "True":
                context: "strings"
                type: "positive_check"
              "False":
                context: "strings"
                type: "negative_ballot"
      verbs_misc:
        header: "Other:"
        path: "verbs_misc"
        type: "raw"
        formatter: "list"
      verbs_patch:
        header: "Patch:"
        path: "verbs_patch"
        type: "bool"
        formatter: "value_mapper"
        formatting:
          mapping:
            substitutions:
              "True":
                context: "strings"
                type: "positive_check"
              "False":
                context: "strings"
                type: "negative_ballot"
      verbs_update:
        header: "Update:"
        path: "verbs_update"
        type: "bool"
        formatter: "value_mapper"
        formatting:
          mapping:
            substitutions:
              "True":
                context: "strings"
                type: "positive_check"
              "False":
                context: "strings"
                type: "negative_ballot"
      verbs_watch:
        header: "Watch:"
        path: "verbs_watch"
        type: "bool"
        formatter: "value_mapper"
        formatting:
          mapping:
            substitutions:
              "True":
                context: "strings"
                type: "positive_check"
              "False":
                context: "strings"
                type: "negative_ballot"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    "Cluster Role Label Selectors":
      key: "s"
      modifier: "shift"
      read_only: true
      helptext: "Show Cluster Role label selectors"
      widget: "windowwidget"
      widget_args:
        title: "Cluster Role Label Selector:"
        itemgetter: "get_selector_list"
        itemgetter_args:
          path: "aggregationRule#clusterRoleSelectors"
