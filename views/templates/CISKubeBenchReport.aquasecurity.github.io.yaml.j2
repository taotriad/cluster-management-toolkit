---
kind: "CISKubeBenchReport"
api_family: "aquasecurity.github.io"
default_command: "ciskubebenchreports"
command:
  - "kubebench"
listview:
  name: "CIS Kube-Bench Reports"
  group: "Security"
  field_indexes:
    Wide:
      fields: ["name", "controller", "scanner",
               "severity_fail", "severity_warn",
               "severity_info", "severity_pass", "age"]
    Normal:
      fields: ["name", "controller", "scanner",
               "severity_fail", "severity_warn",
               "severity_info", "severity_pass", "age"]
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    scanner:
      header: "Scanner:"
      paths:
        - path: [["report#scanner#name"], ["report#scanner#version"]]
          pathtype: "tuple"
      formatter: "list"
      formatting:
        field_colors:
          - type: "generic"
          - type: "version"
        field_separators:
          - type: "version"
    severity_fail:
      header: "Fail:"
      path: "report#summary#failCount"
      type: "raw"
      formatter: "value_mapper"
      formatting:
        mapping:
          ranges:
            - min: 0
              max: 1
              field_colors:
                - context: "types"
                  type: "watermark_low"
            - default: true
              field_colors:
                - context: "types"
                  type: "watermark_high"
      align: "right"
    severity_info:
      header: "Info:"
      path: "report#summary#infoCount"
      type: "raw"
      formatter: "value_mapper"
      formatting:
        mapping:
          ranges:
            - min: 0
              max: 1
              field_colors:
                - context: "types"
                  type: "watermark_low"
            - default: true
              field_colors:
                - context: "types"
                  type: "watermark_medium"
      align: "right"
    severity_pass:
      header: "Pass:"
      path: "report#summary#passCount"
      type: "int"
      formatter: "numerical"
      align: "right"
    severity_warn:
      header: "Warn:"
      path: "report#summary#warnCount"
      type: "raw"
      formatter: "value_mapper"
      formatting:
        mapping:
          ranges:
            - min: 0
              max: 1
              field_colors:
                - context: "types"
                  type: "watermark_low"
            - default: true
              field_colors:
                - context: "types"
                  type: "watermark_medium"
      align: "right"
infoview:
  name: "CSI Kube-Bench Report Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "scanner", "vendor", "severity_header",
                 "severity_fail", "severity_warn", "severity_info",
                 "severity_pass", "update_timestamp"]
    rows:
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      scanner:
        header: [["Scanner:", ["main", "infoheader"]]]
        paths:
          - path: [["report#scanner#name"], ["report#scanner#version"]]
            pathtype: "tuple"
        formatter: "list"
        formatting:
          field_colors:
            - type: "generic"
            - type: "version"
          field_separators:
            - type: "version"
      severity_fail:
        header: [["  Fail:", ["main", "infoheader"]]]
        path: "report#summary#failCount"
        type: "raw"
        formatter: "value_mapper"
        formatting:
          mapping:
            ranges:
              - min: 0
                max: 1
                field_colors:
                  - context: "types"
                    type: "watermark_low"
              - default: true
                field_colors:
                  - context: "types"
                    type: "watermark_high"
      severity_info:
        header: [["  Info:", ["main", "infoheader"]]]
        path: "report#summary#infoCount"
        type: "raw"
        formatter: "value_mapper"
        formatting:
          mapping:
            ranges:
              - min: 0
                max: 1
                field_colors:
                  - context: "types"
                    type: "watermark_low"
              - default: true
                field_colors:
                  - context: "types"
                    type: "watermark_medium"
      severity_header:
        header: [["Severity:", ["main", "infoheader"]]]
      severity_pass:
        header: [["  Pass:", ["main", "infoheader"]]]
        path: "report#summary#passCount"
        type: "raw"
        formatter: "numerical"
      update_timestamp:
        header: [["Last Update:", ["main", "infoheader"]]]
        paths:
          - path: ["report#updateTimestamp"]
            type: "timestamp"
            default: -1
        formatter: "timestamp"
      vendor:
        header: [["Vendor:", ["main", "infoheader"]]]
        path: "report#scanner#vendor"
        type: "str"
      severity_warn:
        header: [["  Warn:", ["main", "infoheader"]]]
        path: "report#summary#warnCount"
        type: "raw"
        formatter: "value_mapper"
        formatting:
          mapping:
            ranges:
              - min: 0
                max: 1
                field_colors:
                  - context: "types"
                    type: "watermark_low"
              - default: true
                field_colors:
                  - context: "types"
                    type: "watermark_medium"
  listpad:
    on_activation:
      call: "resourceinfodispatch"
      kind: "__CISKubeBenchReportTestSetData"
      api_family: "aquasecurity.github.io"
    listgetter: "listgetter_path"
    listgetter_args:
      path: "report#sections"
      subpath: "tests"
      path_fields:
        - "node_type"
    infogetter: "generic_infogetter"
    field_indexes:
      Normal:
        fields: ["test_set_id", "test_set", "category",
                 "fail", "warn", "info", "pass"]
        sortcolumn: "test_set_id"
    fields:
      category:
        header: "Category:"
        path: "node_type"
        type: "str"
      test_set_id:
        header: "ID#:"
        path: "section"
        type: "str"
        formatter: "numerical"
        align: "right"
      fail:
        header: "Fail:"
        path: "fail"
        type: "raw"
        align: "right"
        formatter: "value_mapper"
        formatting:
          mapping:
            ranges:
              - min: 0
                max: 1
                field_colors:
                  - context: "types"
                    type: "watermark_low"
              - default: true
                field_colors:
                  - context: "types"
                    type: "watermark_high"
      info:
        header: "Info:"
        path: "info"
        type: "raw"
        align: "right"
        formatter: "value_mapper"
        formatting:
          mapping:
            ranges:
              - min: 0
                max: 1
                field_colors:
                  - context: "types"
                    type: "watermark_low"
              - default: true
                field_colors:
                  - context: "types"
                    type: "watermark_medium"
      pass:
        header: "Pass:"
        path: "pass"
        type: "int"
        formatter: "numerical"
        align: "right"
      test_set:
        header: "Test Set:"
        path: "desc"
        type: "str"
      warn:
        header: "Warn:"
        path: "warn"
        type: "raw"
        align: "right"
        formatter: "value_mapper"
        formatting:
          mapping:
            ranges:
              - min: 0
                max: 1
                field_colors:
                  - context: "types"
                    type: "watermark_low"
              - default: true
                field_colors:
                  - context: "types"
                    type: "watermark_medium"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
