---
kind: "ConsoleCLIDownload"
api_family: "console.openshift.io"
default_command: "consoleclidownloads"
listview:
  name: "Console CLI Downloads"
  group: "OpenShift"
  field_indexes:
    Wide:
      fields: ["name", "display_name", "controller", "age"]
    Normal:
      fields: ["name", "display_name", "age"]
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    display_name:
      header: "Display Name:"
      path: "spec#displayName"
      type: "str"
infoview:
  name: "Console CLI Download Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["display_name", "controller"]
    rows:
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      display_name:
        header: [["Display Name:", ["main", "infoheader"]]]
        path: "spec#displayName"
        type: "str"
  logpad:
    timestamps: false
    infogetter: "logpad_msg_getter"
    infogetter_args:
      path: "spec#description"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    "Show Download Links":
      key: "d"
      modifier: "shift"
      read_only: true
      helptext: "Show download links"
      widget: "windowwidget"
      widget_args:
        title: "Download links:"
        headers: ["Description:", "URL:"]
        selectable: false
        itemgetter: "get_list_fields"
        itemgetter_args:
          path: "spec#links"
          fields:
            - "text"
            - "href"
        # Not supported for now
        sortcolumn: "text"
