---
kind: "OperatorCondition"
api_family: "operators.coreos.com"
default_command: "operatorconditions"
command:
  - "opconds"
  - "opcond"
listview:
  name: "Operator Conditions"
  group: "API & Extendability"
  field_indexes:
    Normal:
      fields: ["namespace", "name", "controller", "age"]
      sortcolumn: "namespace"
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
infoview:
  name: "Operator Condition Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller"]
    rows:
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    "Show Deployment list":
      key: "d"
      modifier: "shift"
      read_only: true
      helptext: "List Deployments"
      widget: "windowwidget"
      widget_args:
        title: "Deployments:"
        headers: ["Namespace:", "Name:"]
        selectable: true
        itemgetter: "get_list_as_list"
        itemgetter_args:
          paths: ["metadata#namespace", "spec#deployments"]
        # Not supported for now
        sortcolumn: "namespace"
      action: "call"
      action_call: "resourceinfodispatch_with_lookup"
      action_args:
        kind: "Deployment"
        api_family: "apps"
        namespace_path: 0
        name_path: 1
    "Show Service Account list":
      key: "s"
      modifier: "shift"
      read_only: true
      helptext: "List Service Accounts"
      widget: "windowwidget"
      widget_args:
        title: "Service Accounts:"
        headers: ["Namespace:", "Name:"]
        selectable: true
        itemgetter: "get_list_as_list"
        itemgetter_args:
          paths: ["metadata#namespace", "spec#serviceAccounts"]
        # Not supported for now
        sortcolumn: "namespace"
      action: "call"
      action_call: "resourceinfodispatch_with_lookup"
      action_args:
        kind: "ServiceAccount"
        namespace_path: 0
        name_path: 1
