---
kind: "ClusterNetwork"
api_family: "network.openshift.io"
default_command: "clusternetworks"
listview:
  name: "Cluster Networks"
  group: "OpenShift"
  field_indexes:
    Wide:
      fields: ["name", "controller", "cluster_network", "service_network",
               "plugin_name", "age"]
    Normal:
      fields: ["name", "cluster_network", "service_network",
               "plugin_name", "age"]
  fields:
    cluster_network:
      header: "Cluster Network:"
      path: "network"
      type: "str"
      formatter: "address"
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    plugin_name:
      header: "Plugin Name:"
      path: "pluginName"
      type: "str"
    service_network:
      header: "Service Network:"
      path: "serviceNetwork"
      type: "str"
      formatter: "address"
infoview:
  name: "Cluster Network Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "cluster_network", "service_network",
                 "vxlan_port", "mtu", "plugin_name"]
    rows:
      cluster_network:
        header: [["Cluster Network:", ["main", "infoheader"]]]
        path: "network"
        type: "str"
        formatter: "address"
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      mtu:
        header: [["MTU:", ["main", "infoheader"]]]
        path: "mtu"
        type: "int"
        formatter: "numerical"
      plugin_name:
        header: [["Plugin Name:", ["main", "infoheader"]]]
        path: "pluginName"
        type: "str"
      service_network:
        header: [["Service Network:", ["main", "infoheader"]]]
        path: "serviceNetwork"
        type: "str"
        formatter: "address"
      vxlan_port:
        header: [["VXLAN Port:", ["main", "infoheader"]]]
        path: "vxlanPort"
        type: "int"
        formatting:
          field_colors:
            - type: "port"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
