---
kind: "Image"
api_family: "caching.internal.knative.dev"
default_command: "images.caching.internal.knative.dev"
command:
  - "image.caching.internal.knative.dev"
  - "images.knative"
  - "image.knative"
  - "knimages"
  - "knimage"
  - "knimg"
listview:
  name: "Images"
  group: "Knative"
  field_indexes:
    Normal:
      fields: ["namespace", "name", "controller", "age"]
      sortcolumn: "namespace"
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
infoview:
  name: "Image Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "image"]
    rows:
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      image:
        header: [["Image:", ["main", "infoheader"]]]
        path: "spec#image"
        type: "str"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
