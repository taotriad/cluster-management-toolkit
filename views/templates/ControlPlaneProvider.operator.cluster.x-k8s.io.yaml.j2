---
kind: "ControlPlaneProvider"
api_family: "operator.cluster.x-k8s.io"
default_command: "controlplaneproviders"
command:
  - "controlplaneprovs"
  - "controlplaneprov"
  - "cpprovs"
  - "cpprov"
listview:
  name: "Control Plane Providers"
  group: "Cluster Configuration"
  field_indexes:
    Normal:
      fields: ["namespace", "name", "installed_version",
               "condition_ready", "age"]
      sortcolumn: "namespace"
  fields:
    installed_version:
      header: "Installed Version:"
      path: "status#installedVersion"
      type: "str"
      formatting:
        field_colors:
          - type: "version"
    {%- for line in field_condition_ready.split("\n") %}
    {{ line }}
    {%- endfor %}
infoview:
  name: "Control Plane Provider Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["installed_version", "contract", "condition_ready"]
    rows:
      {%- for line in row_condition_ready.split("\n") %}
      {{ line }}
      {%- endfor %}
      contract:
        header: [["Contract:", ["main", "infoheader"]]]
        path: "status#contract"
        type: "str"
        formatting:
          field_colors:
            - type: "version"
      installed_version:
        header: [["Installed Version:", ["main", "infoheader"]]]
        path: "status#installedVersion"
        type: "str"
        formatting:
          field_colors:
            - type: "version"
