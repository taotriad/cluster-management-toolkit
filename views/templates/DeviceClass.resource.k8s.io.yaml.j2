---
kind: "DeviceClass"
api_family: "resource.k8s.io"
default_command: "deviceclasses"
command:
  - "devclasses"
  - "devclass"
listview:
  name: "Device Classes"
  group: "Dynamic Resource Allocation"
  field_indexes:
    Normal:
      fields: ["name", "extended_resource", "controller", "age"]
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    extended_resource:
      header: "Extended Resource:"
      path: "spec#extendedResourceName"
      default: "<unset>"
      type: "str"
infoview:
  name: "Device Class Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "extended_resource"]
    rows:
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      extended_resource:
        header: [["Extended Resource:", ["main", "infoheader"]]]
        path: "spec#extendedResourceName"
        default: "<unset>"
        type: "str"
  listpad:
    listgetter: "listgetter_path"
    listgetter_args:
      path: "spec#selectors"
    infogetter: "generic_infogetter"
    field_indexes:
      Normal:
        fields: ["selectors"]
    fields:
      selectors:
        header: "Selectors:"
        paths:
          - path: []
            pathtype: "selectors"
            default: "<none>"
        type: "str"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    "Device class configuration":
      key: "c"
      read_only: true
      helptext: "Show device class configuration"
      action: "call"
      action_call: "view_yaml"
      action_args:
        title: "Device Class Configuration"
        _pass_obj: true
        path: "spec#config"
