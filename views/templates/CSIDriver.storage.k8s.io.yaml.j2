---
kind: "CSIDriver"
api_family: "storage.k8s.io"
default_command: "csidrivers"
command:
  - "csidrvs"
  - "csidrv"
listview:
  name: "CSI Drivers"
  group: "Storage & Backups"
  field_indexes:
    Wide:
      fields: ["name", "controller", "attach_required", "pod_info_on_mount",
               "volume_lifecycle_modes", "age"]
    Normal:
      fields: ["name", "attach_required", "pod_info_on_mount",
               "volume_lifecycle_modes", "age"]
  fields:
    attach_required:
      header: "Attach Required:"
      path: "spec#attachRequired"
      type: "bool"
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    pod_info_on_mount:
      header: "Pod Info on Mount:"
      path: "spec#podInfoOnMount"
      type: "bool"
    volume_lifecycle_modes:
      header: "Modes:"
      paths:
        - path: "spec#volumeLifecycleModes"
          pathtype: "list"
      formatter: "list"
  actions:
    actionlist:
      "Delete resource":
        description: "Delete resource"
        category: "Resource Level"
        confirm: true
        actionfunc: "delete_resource"
infoview:
  name: "CSI Driver Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "attach_required", "pod_info_on_mount",
                 "fs_group_policy", "selinux_mount", "requires_republish",
                 "node_allocatable_update_period_seconds",
                 "storage_capacity", "volume_lifecycle_modes"]
    rows:
      node_allocatable_update_period_seconds:
        header: [["Node Allocatable Update Period:", ["main", "infoheader"]]]
        path: "spec#nodeAllocatableUpdatePeriodSeconds"
        default: "<unset>"
        type: "int"
        formatter: "numerical"
        formatting:
          unit: "s"
      attach_required:
        header: [["Attach Required:", ["main", "infoheader"]]]
        path: "spec#attachRequired"
        type: "bool"
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      fs_group_policy:
        header: [["FS Group Policy:", ["main", "infoheader"]]]
        path: "spec#fsGroupPolicy"
        type: "str"
      pod_info_on_mount:
        header: [["Pod Info on Mount:", ["main", "infoheader"]]]
        path: "spec#podInfoOnMount"
        type: "bool"
      requires_republish:
        header: [["Requires Republish:", ["main", "infoheader"]]]
        path: "spec#requiresRepublish"
        type: "bool"
      selinux_mount:
        header: [["SELinux Mount:", ["main", "infoheader"]]]
        path: "spec#seLinuxMount"
        type: "bool"
      storage_capacity:
        header: [["Storage Capacity:", ["main", "infoheader"]]]
        path: "spec#storageCapacity"
        type: "bool"
      volume_lifecycle_modes:
        header: [["Modes:", ["main", "infoheader"]]]
        paths:
          - path: "spec#volumeLifecycleModes"
            pathtype: "list"
        formatter: "list"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
