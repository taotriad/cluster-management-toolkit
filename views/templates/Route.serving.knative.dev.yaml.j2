---
kind: "Route"
api_family: "serving.knative.dev"
default_command: "routes.serving.knative.dev"
command:
  - "routes.knative"
  - "route.knative"
  - "knroutes"
  - "knroute"
listview:
  name: "Routes"
  group: "Knative"
  field_indexes:
    Normal:
      fields: ["namespace", "name", "controller",
               "condition_ready", "age", "reason"]
  fields:
    {%- for line in field_condition_ready.split("\n") %}
    {{ line }}
    {%- endfor %}
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    reason:
      header: "Reason:"
      paths:
        - path: "status#conditions"
          pathtype: "items"
          subpath: "message"
          when:
            - key: "type"
              eq: "Ready"
      type: "str"
  actions:
    actionlist:
      "Delete resource":
        description: "Delete resource"
        category: "Resource Level"
        confirm: true
        actionfunc: "delete_resource"
infoview:
  name: "Route Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "url", "condition_ready", "reason"]
    rows:
      {%- for line in row_condition_ready.split("\n") %}
      {{ line }}
      {%- endfor %}
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      reason:
        header: [["Reason:", ["main", "infoheader"]]]
        paths:
          - path: "status#conditions"
            pathtype: "items"
            subpath: "message"
            when:
              - key: "type"
                eq: "Ready"
        type: "list"
        formatter: "list"
      url:
        header: [["URL:", ["main", "infoheader"]]]
        path: "status#address#url"
        type: "str"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    "Show traffic info":
      key: "t"
      modifier: "shift"
      read_only: true
      helptext: "Show traffic info"
      widget: "windowwidget"
      widget_args:
        headers: ["Revision Name:", "Percent:", "Latest:"]
        itemgetter: "get_list_fields"
        itemgetter_args:
          path: "status#traffic"
          fields:
            - "revisionName"
            - "percent"
            - "latestRevision"
        # This isn't supported for now
        sortcolumn: "revision_name"
