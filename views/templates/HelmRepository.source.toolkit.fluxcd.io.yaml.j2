---
kind: "HelmRepository"
api_family: "source.toolkit.fluxcd.io"
default_command: "helmrepositories.source.toolkit.fluxcd.io"
command:
  - "helmrepos.fluxcd"
  - "helmrepo.fluxcd"
  - "helmrepos.flux"
  - "helmrepo.flux"
listview:
  name: "Helm Repositories"
  group: "CI / CD"
  field_indexes:
    Wide:
      fields: ["namespace", "name", "url", "status", "condition_ready", "age"]
      sortcolumn: "namespace"
    Normal:
      fields: ["namespace", "name", "status", "condition_ready", "age"]
      sortcolumn: "namespace"
  fields:
    {%- for line in field_condition_ready.split("\n") %}
    {{ line }}
    {%- endfor %}
    status:
      header: "Status:"
      paths:
        - path: "status#conditions"
          pathtype: "items"
          subpath: "reason"
          when:
            - key: "type"
              eq: "Ready"
      default: "<unset>"
      type: "str"
    url:
      header: "URL:"
      path: "spec#url"
      default: "<unset>"
      type: "str"
      formatter: "address"
infoview:
  name: "Helm Repository Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["provider", "type", "interval", "url",
                 "status", "condition_ready"]
    rows:
      {%- for line in row_condition_ready.split("\n") %}
      {{ line }}
      {%- endfor %}
      interval:
        header: [["Interval:", ["main", "infoheader"]]]
        path: "spec#interval"
        type: "str"
        formatter: "numerical"
      provider:
        header: [["Provider:", ["main", "infoheader"]]]
        path: "spec#provider"
        default: "<unset>"
        type: "str"
      status:
        header: [["Status:", ["main", "infoheader"]]]
        paths:
          - path: "status#conditions"
            pathtype: "items"
            subpath: "reason"
            when:
              - key: "type"
                eq: "Ready"
        default: "<unset>"
        type: "str"
      type:
        header: [["Type:", ["main", "infoheader"]]]
        path: "spec#type"
        default: "<unset>"
        type: "str"
      url:
        header: [["URL:", ["main", "infoheader"]]]
        path: "spec#url"
        default: "<unset>"
        type: "str"
        formatter: "address"
