---
kind: "MachineSet"
api_family: "cluster.x-k8s.io"
default_command: "machinesets.cluster.x-k8s.io"
command:
  - "x-machinesets"
  - "x-machineset"
  - "x-ms"
listview:
  name: "Machine Sets"
  group: "Cluster Configuration"
  field_indexes:
    Wide:
      fields: ["namespace", "name", "controller", "cluster",
               "replicas", "ready", "available", "age", "version"]
      sortcolumn: "namespace"
    Normal:
      fields: ["namespace", "name", "cluster", "replicas", "ready",
               "available", "age", "version"]
      sortcolumn: "namespace"
  fields:
    available:
      header: "Available:"
      path: "status#availableReplicas"
      type: "int"
      formatter: "numerical"
      align: "right"
    cluster:
      header: "Cluster:"
      path: "spec#clusterName"
      type: "str"
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    ready:
      header: "Ready:"
      path: "status#readyReplicas"
      type: "int"
      formatter: "numerical"
      align: "right"
    replicas:
      header: "Replicas:"
      path: "status#replicas"
      type: "int"
      formatter: "numerical"
      align: "right"
    version:
      header: "Version:"
      path: "spec#template#spec#version"
      type: "str"
      formatting:
        field_colors:
          - type: "version"
infoview:
  name: "Machine Set Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "cluster", "label_selector",
                 "delete_policy", "replicas", "ready", "available",
                 "template_header", "template_cluster_name",
                 "template_failure_domain", "template_bootstrap",
                 "template_infrastructure", "template_version"]
    rows:
      available:
        header: [["Available:", ["main", "infoheader"]]]
        path: "status#availableReplicas"
        type: "int"
        formatter: "numerical"
      cluster:
        header: [["Cl", ["main", "infoheader"]],
                 ["u", ["main", "infoheader_shortcut"]],
                 ["ster:", ["main", "infoheader"]]]
        path: "spec#clusterName"
        type: "str"
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      delete_policy:
        header: [["Delete Policy:", ["main", "infoheader"]]]
        path: "spec#deletion#order"
        default: "Random"
        type: "str"
      label_selector:
        header: [["La", ["main", "infoheader"]],
                 ["b", ["main", "infoheader_shortcut"]],
                 ["el Selector:", ["main", "infoheader"]]]
        paths:
          - path: ["spec#selector#matchLabels"]
            pathtype: "key_value"
            default: ["<none>"]
        formatter: "list"
        formatting:
          field_colors:
            - type: "key"
            - type: "value"
          field_separators:
            - type: "selector"
      ready:
        header: [["Ready:", ["main", "infoheader"]]]
        path: "status#readyReplicas"
        type: "int"
        formatter: "numerical"
      replicas:
        header: [["Replicas:", ["main", "infoheader"]]]
        path: "status#replicas"
        type: "int"
        formatter: "numerical"
      template_bootstrap:
        header: [["  B", ["main", "infoheader"]],
                 ["o", ["main", "infoheader_shortcut"]],
                 ["otstrap:", ["main", "infoheader"]]]
        paths:
          - path: [["spec#template#spec#bootstrap#configRef#kind"],
                   ["spec#template#spec#bootstrap#configRef#apiVersion"],
                   ["spec#template#spec#bootstrap#configRef#name"]]
            pathtype: "tuple"
            type: ["kind", "api_group", "name"]
        default: "<none>"
        formatter: "list"
        formatting:
          field_colors:
            - type: "kind"
            - type: "api_group"
            - type: "generic"
          field_separators:
            - type: "kind_api_group"
            - type: "kind"
      template_cluster_name:
        header: [["  Cluster Name:", ["main", "infoheader"]]]
        path: "spec#template#spec#clusterName"
        type: "str"
      template_failure_domain:
        header: [["  Failure Domain:", ["main", "infoheader"]]]
        path: "spec#template#spec#failureDomain"
        default: "<unset>"
        type: "str"
      template_header:
        header: [["T", ["main", "infoheader_shortcut"]],
                 ["emplate:", ["main", "infoheader"]]]
      template_infrastructure:
        header: [["  ", ["main", "infoheader"]],
                 ["I", ["main", "infoheader_shortcut"]],
                 ["nfrastructure:", ["main", "infoheader"]]]
        paths:
          - path: [["spec#template#spec#infrastructureRef#kind"],
                   ["spec#template#spec#infrastructureRef#apiVersion"],
                   ["spec#template#spec#infrastructureRef#name"]]
            pathtype: "tuple"
            type: ["kind", "api_group", "name"]
        default: "<none>"
        formatter: "list"
        formatting:
          field_colors:
            - type: "kind"
            - type: "api_group"
            - type: "generic"
          field_separators:
            - type: "kind_api_group"
            - type: "kind"
      template_version:
        header: [["  Version:", ["main", "infoheader"]]]
        path: "spec#template#spec#version"
        type: "str"
        formatting:
          field_colors:
            - type: "version"
  listpad:
    listgetter: "generic_listgetter"
    listgetter_args:
      _kind: "Machine"
      _label_selector_path: "spec#nodeSelector#matchLabels"
      _none_on_empty_selector: true
    infogetter: "generic_infogetter"
    on_activation:
      call: "resourceinfodispatch"
      kind: "Node"
    field_indexes:
      Normal:
        fields: ["namespace", "name", "provider_id", "phase", "age", "taints"]
        sortcolumn: "namespace"
    fields:
      phase:
        header: "Phase:"
        path: "status#phase"
        type: "str"
        formatter: "value_mapper"
        formatting:
          mapping:
            mappings:
              Deleting:
                field_colors:
                  - context: "main"
                    type: "status_pending"
              Failed:
                field_colors:
                  - context: "main"
                    type: "status_not_ok"
              Provisioned:
                field_colors:
                  - context: "main"
                    type: "status_ok"
              Provisioning:
                field_colors:
                  - context: "main"
                    type: "status_pending"
              Running:
                field_colors:
                  - context: "main"
                    type: "status_ok"
      provider_id:
        header: "Provider ID:"
        path: "spec#providerID"
        type: "str"
      taints:
        header: "Taints:"
        paths:
          - path: "spec#taints"
            pathtype: "items"
            subpaths:
              - "key"
              - "value"
              - "effect"
        formatter: "list"
        formatting:
          field_colors:
            - type: "key"
            - type: "value"
            - type: "effect"
          field_separators:
            - type: "equals"
            - type: "keyvalue"
          mapping:
            mappings:
              NoSchedule:
                field_colors:
                  - context: "main"
                    type: "status_not_ok"
              PreferNoSchedule:
                field_colors:
                  - context: "main"
                    type: "status_warning"
              NoExecute:
                field_colors:
                  - context: "main"
                    type: "status_not_ok"
  shortcuts:
    "Label Selector":
      key: "b"
      read_only: true
      helptext: "Show label selector"
      widget: "windowwidget"
      widget_args:
        title: "Label Selector:"
        headers: ["Key:", "Value:"]
        itemgetter: "get_key_value"
        itemgetter_args:
          path: "spec#selector#matchLabels"
    "Machine Template":
      key: "t"
      modifier: "shift"
      read_only: true
      helptext: "Show Machine template"
      action: "call"
      action_call: "view_yaml"
      action_args:
        title: "Machine Template"
        _pass_obj: true
        path: "spec#template"
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    "Open Cluster":
      key: "u"
      read_only: true
      helptext: "Open info page for Cluster"
      action: "call"
      action_call: "resourceinfodispatch_with_lookup"
      action_args:
        _pass_obj: true
        kind: "Cluster"
        api_family: "cluster.x-k8s.io"
        namespace_path: "metadata#namespace"
        name_path: "spec#clusterName"
    "Open bootstrap":
      key: "o"
      read_only: true
      helptext: "Open info page for bootstrap"
      action: "call"
      action_call: "resourceinfodispatch_with_lookup"
      action_args:
        _pass_obj: true
        api_version_path: "spec#template#spec#bootstrap#configRef#apiVersion"
        kind_path: "spec#template#spec#bootstrap#configRef#kind"
        namespace_path: "metadata#namespace"
        name_path: "spec#template#spec#bootstrap#configRef#name"
    "Open infrastructure":
      key: "i"
      modifier: "shift"
      read_only: true
      helptext: "Open info page for infrastructure"
      action: "call"
      action_call: "resourceinfodispatch_with_lookup"
      action_args:
        _pass_obj: true
        api_version_path: "spec#template#spec#infrastructureRef#apiVersion"
        kind_path: "spec#template#spec#infrastructureRef#kind"
        namespace_path: "metadata#namespace"
        name_path: "spec#template#spec#infrastructureRef#name"
