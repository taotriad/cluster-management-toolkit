---
kind: "App"
api_family: "catalog.cattle.io"
default_command: "apps.catalog.cattle.io"
command:
  - "apps.cattle"
  - "app.cattle"
listview:
  name: "Apps"
  group: "Rancher"
  field_indexes:
    Wide:
      fields: ["namespace", "name", "controller", "version", "status", "age",
               "description", "chart", "release_name", "release_version"]
      sortcolumn: "namespace"
    Normal:
      fields: ["namespace", "name", "version", "status", "age", "description"]
      sortcolumn: "namespace"
  fields:
    chart:
      header: "Chart:"
      path: "spec#chart#metadata#name"
      type: "str"
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    description:
      header: "Description:"
      path: "spec#info#description"
      type: "str"
    release_name:
      header: "Release Name:"
      path: "spec#name"
      type: "str"
    release_version:
      header: "Release Version:"
      path: "spec#version"
      type: "str"
      formatting:
        field_colors:
          - type: "version"
    status:
      header: "Status:"
      path: "spec#info#status"
      default: "<unset>"
      type: "str"
      formatter: "value_mapper"
      formatting:
        mapping:
          mappings:
            deployed:
              field_colors:
                - context: "main"
                  type: "status_done"
            "<unset>":
              field_colors:
                - context: "types"
                  type: "unset"
    version:
      header: "Version:"
      path: "spec#chart#metadata#version"
      type: "str"
      formatting:
        field_colors:
          - type: "version"
infoview:
  name: "App Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "chart", "version", "release_name",
                 "release_version", "description", "status"]
    rows:
      chart:
        header: [["Chart:", ["main", "infoheader"]]]
        path: "spec#chart#metadata#name"
        type: "str"
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      description:
        header: [["Description:", ["main", "infoheader"]]]
        path: "spec#info#description"
        type: "str"
      release_name:
        header: [["Release Name:", ["main", "infoheader"]]]
        path: "spec#name"
        type: "str"
      release_version:
        header: [["Release Version:", ["main", "infoheader"]]]
        path: "spec#version"
        type: "str"
        formatting:
          field_colors:
            - type: "version"
      status:
        header: [["Status:", ["main", "infoheader"]]]
        path: "spec#info#status"
        type: "str"
        formatter: "value_mapper"
        formatting:
          mapping:
            mappings:
              deployed:
                field_colors:
                  - context: "main"
                    type: "status_done"
              "<unset>":
                field_colors:
                  - context: "types"
                    type: "unset"
      version:
        header: [["Version:", ["main", "infoheader"]]]
        path: "spec#chart#metadata#version"
        type: "str"
        formatting:
          field_colors:
            - type: "version"
  logpad:
    infogetter: "logpad_formatted"
    infogetter_args:
      path: "spec#info#readme"
      formatter: "render_markdown"
    timestamps: false
  shortcuts:
    "Notes":
      key: "o"
      read_only: true
      helptext: "Show notes"
      widget: "windowwidget"
      widget_args:
        title: "Notes:"
        itemgetter: "get_strings_from_string"
        itemgetter_args:
          path: "spec#info#notes"
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
