---
kind: "GraphRevision"
api_family: "internal.kro.run"
default_command: "graphrevisions"
command:
  - "graphrevs"
  - "graphrev"
listview:
  name: "Graph Revisions"
  group: "API & Extendability"
  field_indexes:
    Wide:
      fields: ["name", "rgd", "revision", "hash", "condition_ready", "age",
               "topological_order"]
    Normal:
      fields: ["name", "rgd", "revision", "condition_ready", "age"]
  fields:
    {%- for line in field_condition_ready.split("\n") %}
    {{ line }}
    {%- endfor %}
    hash:
      header: "Hash:"
      path: "metadata#labels#kro.run/graph-revision-hash"
      default: "<unset>"
      type: "str"
      formatter: "hex"
    revision:
      header: "Revision:"
      path: "spec#revision"
      default: "<unset>"
      type: "int"
      formatter: "numerical"
      align: "right"
    rgd:
      header: "RGD:"
      path: "spec#snapshot#name"
      default: "<unset>"
      type: "str"
    topological_order:
      header: "Topological Order:"
      path: "status#topologicalOrder"
      default: ["<none>"]
      type: "raw"
      formatter: "list"
infoview:
  name: "Resource Graph Definition Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["rgd", "hash", "topological_order", "revision",
                 "condition_ready"]
    rows:
      {%- for line in row_condition_ready.split("\n") %}
      {{ line }}
      {%- endfor %}
      hash:
        header: [["Hash:", ["main", "infoheader"]]]
        path: "metadata#labels#kro.run/graph-revision-hash"
        default: "<unset>"
        type: "str"
        formatter: "hex"
      revision:
        header: [["Revision:", ["main", "infoheader"]]]
        path: "spec#revision"
        default: "<unset>"
        type: "int"
        formatter: "numerical"
      rgd:
        header: [["Resource Graph Definition:", ["main", "infoheader"]]]
        path: "spec#snapshot#name"
        default: "<unset>"
        type: "str"
      topological_order:
        header: [["T", ["main", "infoheader_shortcut"]],
                 ["opological Order:", ["main", "infoheader"]]]
        path: "status#topologicalOrder"
        default: ["<none>"]
        type: "raw"
        formatter: "list"
  shortcuts:
    "Show Topological Order":
      key: "t"
      modifier: "shift"
      read_only: true
      helptext: "Show topological order"
      widget: "windowwidget"
      widget_args:
        title: "Topological Order:"
        itemgetter: "get_list_as_list"
        itemgetter_args:
          path: "status#topologicalOrder"
