---
kind: "PodAutoscaler"
api_family: "autoscaling.internal.knative.dev"
default_command: "podautoscalers.autoscaling.internal.knative.dev"
command:
  - "podautoscaler.autoscaling.internal.knative.dev"
  - "podautoscalers.knative"
  - "podautoscaler.knative"
  - "knpodautoscalers"
  - "knpodautoscaler"
listview:
  name: "Pod Autoscalers"
  group: "Knative"
  field_indexes:
    Normal:
      fields: ["namespace", "name", "controller",
               "condition_ready", "age", "reason"]
  fields:
    {%- for line in field_condition_ready.split("\n") %}
    {{ line }}
    {%- endfor %}
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    reason:
      header: "Reason:"
      paths:
        - path: "status#conditions"
          pathtype: "items"
          subpath: "message"
          when:
            - key: "type"
              eq: "Ready"
      type: "str"
infoview:
  name: "Pod Autoscaler Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "protocol_type", "reachability",
                 "scale_target_reference", "condition_ready", "reason"]
    rows:
      {%- for line in row_condition_ready.split("\n") %}
      {{ line }}
      {%- endfor %}
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      protocol_type:
        header: [["Protocol Type:", ["main", "infoheader"]]]
        path: "spec#protocolType"
        type: "str"
      reachability:
        header: [["Reachability:", ["main", "infoheader"]]]
        path: "spec#reachability"
        type: "str"
      reason:
        header: [["Reason:", ["main", "infoheader"]]]
        paths:
          - path: "status#conditions"
            pathtype: "items"
            subpath: "message"
            when:
              - key: "type"
                eq: "Ready"
        type: "list"
        formatter: "list"
      scale_target_reference:
        header: [["S", ["main", "infoheader_shortcut"]],
                 ["cale Target Reference:", ["main", "infoheader"]]]
        paths:
          - path: [["spec#scaleTargetRef#kind"],
                   ["spec#scaleTargetRef#apiVersion"],
                   ["spec#scaleTargetRef#name"]]
            pathtype: "tuple"
            type: ["kind", "api_group", "name"]
        formatter: "list"
        formatting:
          field_colors:
            - type: "kind"
            - type: "api_group"
            - type: "generic"
          field_separators:
            - type: "kind_api_group"
            - type: "kind"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    "Scale Target Reference":
      key: "s"
      modifier: "shift"
      read_only: true
      helptext: "Open info page for scale target reference"
      action: "call"
      action_call: "resourceinfodispatch_with_lookup"
      action_args:
        _pass_obj: true
        kind_path: "spec#scaleTargetRef#kind"
        api_version_path: "spec#scaleTargetRef#apiVersion"
        name_path: "spec#scaleTargetRef#name"
        namespace_path: "metadata#namespace"
