---
kind: "VirtinkCluster"
api_family: "infrastructure.cluster.x-k8s.io"
default_command: "virtinkclusters"
command:
  - "viclrs"
  - "viclr"
listview:
  name: "Virtink Clusters"
  group: "Cluster Configuration"
  field_indexes:
    Normal:
      fields: ["namespace", "name", "controller", "cluster", "ready", "age"]
  fields:
    cluster:
      header: "Cluster:"
      path: "metadata#labels#cluster.x-k8s.io/cluster-name"
      type: "str"
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    ready:
      header: "Ready:"
      path: "status#ready"
      default: false
      type: "str"
      formatter: "value_mapper"
      formatting:
        mapping:
          mappings:
            "True":
              field_colors:
                - context: "main"
                  type: "status_ok"
            "False":
              field_colors:
                - context: "main"
                  type: "status_not_ok"
infoview:
  name: "Virtink Cluster Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["cluster", "controller", "control_plane_endpoint", "ready"]
    rows:
      cluster:
        header: [["Cluster:", ["main", "infoheader"]]]
        path: "metadata#labels#cluster.x-k8s.io/cluster-name"
        type: "str"
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      control_plane_endpoint:
        header: [["Control Plane Endpoint:", ["main", "infoheader"]]]
        paths:
          - path: [["spec#controlPlaneEndpoint#host"],
                   ["spec#controlPlaneEndpoint#port"]]
            default: ["<unset>"]
            pathtype: "tuple"
            type: ["name", "name"]
        # FIXME: The formatter needs to be improved to handle lists
        # that contain addresses, etc.
        formatter: "list"
        formatting:
          field_colors:
            - type: "address"
            - type: "port"
          field_separators:
            - type: "port"
      ready:
        header: [["Ready:", ["main", "infoheader"]]]
        path: "status#ready"
        default: false
        type: "str"
        formatter: "value_mapper"
        formatting:
          mapping:
            mappings:
              "True":
                field_colors:
                  - context: "main"
                    type: "status_ok"
              "False":
                field_colors:
                  - context: "main"
                    type: "status_not_ok"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    "View Control Plane Service Template":
      key: "t"
      modifier: "shift"
      read_only: true
      helptext: "Show Control Plane Service Template"
      action: "call"
      action_call: "view_yaml"
      action_args:
        title: "Control Plane Service Template"
        _pass_obj: true
        path: "spec#controlPlaneServiceTemplate"
