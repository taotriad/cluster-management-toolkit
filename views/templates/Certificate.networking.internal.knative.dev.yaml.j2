---
kind: "Certificate"
api_family: "networking.internal.knative.dev"
default_command: "certificates.networking.internal.knative.dev"
command:
  - "kncertificates"
  - "kncerts"
  - "kncert"
listview:
  name: "Certificates"
  group: "Knative"
  field_indexes:
    Normal:
      fields: ["namespace", "name", "age", "condition_ready", "reason"]
      sortcolumn: "namespace"
  fields:
    {%- for line in field_condition_ready.split("\n") %}
    {{ line }}
    {%- endfor %}
    reason:
      header: "Reason:"
      paths:
        - path: "status#conditions"
          pathtype: "items"
          subpath: "message"
          when:
            - key: "type"
              eq: "Ready"
      type: "str"
infoview:
  name: "Certificates Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["dns_names", "certificate", "condition_ready"]
    rows:
      certificate:
        header: [["Certi", ["main", "infoheader"]],
                 ["f", ["main", "infoheader_shortcut"]],
                 ["icate:", ["main", "infoheader"]]]
        path: "spec#secretName"
        default: "<none>"
        type: "str"
      {%- for line in row_condition_ready.split("\n") %}
      {{ line }}
      {%- endfor %}
      dns_names:
        header: [["D", ["main", "infoheader_shortcut"]],
                 ["NS Names:", ["main", "infoheader"]]]
        path: "spec#dnsNames"
        default: ["<unset>"]
        type: "raw"
        formatter: "list"
  shortcuts:
    "List DNS Names":
      key: "d"
      modifier: "shift"
      read_only: true
      helptext: "List DNS names"
      widget: "windowwidget"
      widget_args:
        title: "DNS Names:"
        itemgetter: "get_list_as_list"
        itemgetter_args:
          path: "spec#dnsNames"
        # This isn't supported for now
        sortcolumn: "name"
    "Open Certificate":
      key: "f"
      read_only: true
      helptext: "Open info page for certificate"
      action: "call"
      action_call: "resourceinfodispatch_with_lookup"
      action_args:
        _pass_obj: true
        kind: "Secret"
        name_path: "spec#secretName"
        namespace_path: "metadata#namespace"
