---
kind: "Trial"
api_family: "kubeflow.org"
default_command: "trials"
listview:
  name: "Trials"
  group: "Kubeflow"
  field_indexes:
    Normal:
      fields: ["namespace", "name", "controller", "age"]
      sortcolumn: "namespace"
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
infoview:
  name: "Trial Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "success_condition", "failure_condition"]
    rows:
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      failure_condition:
        header: [["Failure Condition:", ["main", "infoheader"]]]
        path: "spec#failureCondition"
        type: "str"
      success_condition:
        header: [["Success Condition:", ["main", "infoheader"]]]
        path: "spec#successCondition"
        type: "str"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
