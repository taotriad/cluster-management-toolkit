---
kind: "MachineHealthCheck"
api_family: "machine.openshift.io"
default_command: "machinehealthchecks.machine.openshift.io"
command:
  - "os-mhcs"
  - "os-mhc"
listview:
  name: "Machine Health Checks"
  group: "OpenShift"
  field_indexes:
    Wide:
      fields: ["namespace", "name", "controller", "max_unhealthy",
               "expected_machines", "current_healthy", "age"]
      sortcolumn: "namespace"
    Normal:
      fields: ["namespace", "name", "max_unhealthy",
               "expected_machines", "current_healthy", "age"]
      sortcolumn: "namespace"
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    current_healthy:
      header: "Current Healthy:"
      path: "status#currentHealthy"
      default: "0"
      type: "int"
      formatter: "numerical"
      align: "right"
    expected_machines:
      header: "Expected Machines:"
      path: "status#expectedMachines"
      default: "<unset>"
      type: "int"
      formatter: "numerical"
      align: "right"
    max_unhealthy:
      header: "Max Unhealthy:"
      path: "spec#maxUnhealthy"
      type: "raw"
      formatter: "numerical"
      align: "right"
infoview:
  name: "Machine Health Check Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "label_selector",
                 "set_based_selector", "max_unhealthy", "expected_machines",
                 "current_healthy", "remediations_allowed",
                 "node_startup_timeout"]
    rows:
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      current_healthy:
        header: [["Current Healthy:", ["main", "infoheader"]]]
        path: "status#currentHealthy"
        default: "0"
        type: "int"
        formatter: "numerical"
      expected_machines:
        header: [["Expected Machines:", ["main", "infoheader"]]]
        path: "status#expectedMachines"
        default: "<unset>"
        type: "int"
        formatter: "numerical"
      label_selector:
        header: [["La", ["main", "infoheader"]],
                 ["b", ["main", "infoheader_shortcut"]],
                 ["el Selector:", ["main", "infoheader"]]]
        paths:
          - path: ["spec#selector#matchLabels"]
            pathtype: "key_value"
            default: ["<none>"]
        formatter: "list"
        formatting:
          field_colors:
            - type: "key"
            - type: "value"
          field_separators:
            - type: "selector"
      max_unhealthy:
        header: [["Max Unhealthy:", ["main", "infoheader"]]]
        path: "spec#maxUnhealthy"
        type: "raw"
        formatter: "numerical"
      node_startup_timeout:
        header: [["Node Startup Timeout:", ["main", "infoheader"]]]
        path: "spec#nodeStartupTimeout"
        type: "raw"
        formatter: "numerical"
      remediations_allowed:
        header: [["Remediations Allowed:", ["main", "infoheader"]]]
        path: "status#remediationsAllowed"
        default: "<unset>"
        type: "int"
        formatter: "numerical"
      set_based_selector:
        header: [["Set-based Selector:", ["main", "infoheader"]]]
        paths:
          - path: "spec#selector#matchExpressions"
            pathtype: "match_expression"
            default: "<none>"
        formatter: "list"
        formatting:
          field_colors:
            - type: "key"
            - type: "operator"
            - type: "value"
          field_separators:
            - type: "space"
            - type: "no_pad"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    "Label Selector":
      key: "b"
      read_only: true
      helptext: "Show label selector"
      widget: "windowwidget"
      widget_args:
        title: "Label Selector:"
        headers: ["Key:", "Value:"]
        itemgetter: "get_key_value"
        itemgetter_args:
          path: "spec#selector#matchLabels"
    "Unhealthy Conditions":
      key: "u"
      modifier: "shift"
      read_only: true
      helptext: "List unhealthy conditions"
      widget: "windowwidget"
      widget_args:
        title: "Unhealthy Conditions:"
        headers: ["Type:", "Status:", "Timeout:"]
        itemgetter: "get_list_fields"
        itemgetter_args:
          path: "spec#unhealthyConditions"
          fields:
            - "type"
            - "status"
            - "timeout"
        # Not supported for now
        sortcolumn: "type"
