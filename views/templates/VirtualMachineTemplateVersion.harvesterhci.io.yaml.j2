---
kind: "VirtualMachineTemplateVersion"
api_family: "harvesterhci.io"
default_command: "virtualmachinetemplateversions.harvesterhci.io"
command:
  - "virtualmachinetemplateversion.harvesterhci.io"
  - "vmtmplversions.harvesterhci.io"
  - "vmtmplversion.harvesterhci.io"
  - "hvstvmtmplvers"
  - "hvstvmtmplver"
listview:
  name: "Virtual Machine Template Versions"
  group: "Harvester"
  field_indexes:
    Wide:
      fields: ["namespace", "name", "controller", "description", "template_id",
               "version", "age"]
      sortcolumn: "namespace"
    Normal:
      fields: ["namespace", "name", "description", "age"]
      sortcolumn: "namespace"
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    description:
      header: "Description:"
      path: "spec#description"
      default: "<unset>"
      type: "str"
    template_id:
      header: "Template ID:"
      path: "spec#templateId"
      default: "<unset>"
      type: "str"
    version:
      header: "Version:"
      path: "status#version"
      default: "<unset>"
      type: "int"
      formatter: "numerical"
      align: "right"
infoview:
  name: "Virtual Machine Template Version Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["description", "controller", "template_id", "version"]
    rows:
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      description:
        header: [["Description:", ["main", "infoheader"]]]
        path: "spec#description"
        default: "<unset>"
        type: "str"
      template_id:
        header: [["Template ID:", ["main", "infoheader"]]]
        path: "spec#templateId"
        default: "<unset>"
        type: "str"
      version:
        header: [["Version:", ["main", "infoheader"]]]
        path: "status#version"
        default: "<unset>"
        type: "int"
        formatter: "numerical"
  logpad:
    infogetter: "logpad_formatted"
    infogetter_args:
      formatter: "format_yaml"
      path: "spec#vm"
    timestamps: false
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
