---
kind: "Workflow"
api_family: "argoproj.io"
default_command: "workflows"
command:
  - "wfs"
  - "wf"
listview:
  name: "Workflows"
  group: "CI / CD"
  field_indexes:
    Normal:
      fields: ["namespace", "name", "progress", "phase", "age"]
      sortcolumn: "namespace"
  fields:
    progress:
      header: "Progress:"
      paths:
        - path: "status#progress"
          pathtype: "regex"
          regex: "^(.+)/(.+)"
      formatter: "list"
      formatting:
        field_colors:
          - type: "numerical"
          - type: "numerical"
        field_separators:
          - type: "fraction"
      align: "right"
    phase:
      header: "Phase:"
      path: "status#phase"
      type: "str"
      formatter: "value_mapper"
      formatting:
        mapping:
          mappings:
            Error:
              field_colors:
                - context: "main"
                  type: "status_not_ok"
            Failed:
              field_colors:
                - context: "main"
                  type: "status_warning"
            Pending:
              field_colors:
                - context: "main"
                  type: "status_pending"
            Running:
              field_colors:
                - context: "main"
                  type: "status_ok"
            Succeeded:
              field_colors:
                - context: "main"
                  type: "status_done"
  actions:
    actionlist:
      "Delete resource":
        description: "Delete resource"
        category: "Resource Level"
        confirm: true
        actionfunc: "delete_resource"
infoview:
  name: "Workflow Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["entrypoint", "service_account", "progress", "phase"]
    rows:
      entrypoint:
        header: [["Entrypoint:", ["main", "infoheader"]]]
        path: "spec#entrypoint"
        default: "<unset>"
        type: "str"
      service_account:
        header: [["S", ["main", "infoheader_shortcut"]],
                 ["ervice Account:", ["main", "infoheader"]]]
        path: "spec#serviceAccountName"
        type: "str"
      phase:
        header: [["Phase:", ["main", "infoheader"]]]
        path: "status#phase"
        type: "str"
        formatter: "value_mapper"
        formatting:
          mapping:
            mappings:
              Error:
                field_colors:
                  - context: "main"
                    type: "status_not_ok"
              Failed:
                field_colors:
                  - context: "main"
                    type: "status_warning"
              Pending:
                field_colors:
                  - context: "main"
                    type: "status_pending"
              Running:
                field_colors:
                  - context: "main"
                    type: "status_ok"
              Succeeded:
                field_colors:
                  - context: "main"
                    type: "status_done"
      progress:
        header: [["Progress:", ["main", "infoheader"]]]
        paths:
          - path: "status#progress"
            pathtype: "regex"
            regex: "^(.+)/(.+)"
        formatter: "list"
        formatting:
          field_colors:
            - type: "numerical"
            - type: "numerical"
          field_separators:
            - type: "fraction"
  {%- for line in listpad_pod_spec_selector_matchlabels.split("\n") %}
  {{ line }}
  {%- endfor %}
  shortcuts:
    "Service Account":
      key: "s"
      modifier: "shift"
      read_only: true
      helptext: "Open info page for Service Account"
      action: "call"
      action_call: "resourceinfodispatch_with_lookup"
      action_args:
        _pass_obj: true
        kind: "ServiceAccount"
        name_path: "spec#serviceAccountName"
        namespace_path: "metadata#namespace"
    "Templates":
      key: "t"
      modifier: "shift"
      read_only: true
      helptext: "Show templates"
      action: "call"
      action_call: "view_yaml"
      action_args:
        title: "Templates"
        _pass_obj: true
        path: "spec#templates"
        include_root: true
