---
kind: "ResourceQuota"
default_command: "resourcequotas"
command:
  - "quotas"
  - "quota"
  - "rqs"
  - "rq"
listview:
  name: "Resource Quotas"
  group: "Policy"
  field_indexes:
    Wide:
      fields: ["namespace", "name", "controller", "age", "request", "limit"]
      sortcolumn: "namespace"
    Normal:
      fields: ["namespace", "name", "age", "request", "limit"]
      sortcolumn: "namespace"
  fields:
    {%- for line in field_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
    limit:
      header: "Limit:"
      paths:
        - path: "spec#hard"
          pathtype: "key_value"
          when:
            - key_startswith: "limits."
      formatter: "list"
      formatting:
        field_colors:
          - type: "key"
          # Ideally we'd use numerical_with_units
          - type: "numerical"
        field_separators:
          - type: "keyvalue"
    request:
      header: "Request:"
      paths:
        - path: "spec#hard"
          pathtype: "key_value"
          when:
            - key_notstartswith: "limits."
      formatter: "list"
      formatting:
        field_colors:
          - type: "key"
          # Ideally we'd use numerical_with_units
          - type: "numerical"
        field_separators:
          - type: "keyvalue"
infoview:
  name: "Resource Quota Info"
  infopad:
    row_indexes:
      Normal:
        fields: ["controller", "scope_set_based_selector"]
    rows:
      {%- for line in row_controller.split("\n") %}
      {{ line }}
      {%- endfor %}
      scope_set_based_selector:
        header: [["Scope Set-Based Selector:", ["main", "infoheader"]]]
        paths:
          - path: "spec#scopeSelector#matchExpressions"
            pathtype: "match_expression"
            default: "<none>"
        formatter: "list"
        formatting:
          field_colors:
            - type: "key"
            - type: "operator"
            - type: "value"
          field_separators:
            - type: "space"
            - type: "no_pad"
  listpad:
    listgetter: "listgetter_path"
    listgetter_args:
      path: ""
    infogetter: "get_rq_item_info"
    field_indexes:
      Normal:
        fields: ["resource", "used", "hard"]
    fields:
      hard:
        header: "Hard:"
        path: "hard"
        type: "str"
        formatter: "numerical"
        align: "right"
      resource:
        header: "Resource:"
        path: "resource"
        type: "str"
      used:
        header: "Used:"
        path: "used"
        type: "str"
        formatter: "numerical"
        align: "right"
  shortcuts:
    {%- for line in shortcut_controller.split("\n") %}
    {{ line }}
    {%- endfor %}
